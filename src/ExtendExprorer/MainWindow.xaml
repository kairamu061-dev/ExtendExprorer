<Window
    x:Class="ExtendExprorer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:ExtendExprorer.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 復元時に一部パスが見つからなかった場合の通知（10 秒で自動的に閉じる） -->
        <InfoBar x:Name="RestoreInfo" Grid.Row="0"
                 Severity="Warning" IsClosable="True"
                 Message="一部のフォルダが見つからなかったためホームで開きました"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <views:FolderTreePanel x:Name="TreePanel" Grid.Column="0"/>
            <views:LayoutHost x:Name="Host" Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>
