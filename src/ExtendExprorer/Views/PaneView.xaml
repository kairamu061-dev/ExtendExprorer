<UserControl
    x:Class="ExtendExprorer.Views.PaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:ExtendExprorer.Views"
    xmlns:vm="using:ExtendExprorer.ViewModels">
    <!-- 枠線はアクティブペインの強調表示(SetActive)で色が替わる -->
    <!-- 配色はサンプルツール準拠: タブ帯・ツールバー #F0F0F0 / 一覧は白 -->
    <Border x:Name="RootBorder" BorderThickness="1">
        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- タブバー(コンテンツはタブ下の共有領域に表示するため TabViewItem は空) -->
            <TabView x:Name="Tabs" Grid.Row="0"
                     VerticalAlignment="Top"
                     Background="#F0F0F0"
                     IsAddTabButtonVisible="True"
                     CanReorderTabs="False"
                     CanDragTabs="False"
                     AddTabButtonClick="OnAddTabButtonClick"
                     TabCloseRequested="OnTabCloseRequested"
                     SelectionChanged="OnTabSelectionChanged">
                <TabView.TabItemTemplate>
                    <DataTemplate x:DataType="vm:TabViewModel">
                        <TabViewItem Header="{x:Bind Title, Mode=OneWay}" IsClosable="True">
                            <TabViewItem.IconSource>
                                <FontIconSource Glyph="&#xE8B7;"/>
                            </TabViewItem.IconSource>
                        </TabViewItem>
                    </DataTemplate>
                </TabView.TabItemTemplate>
            </TabView>

            <!-- ナビゲーションツールバー(パス表示は address-bar 実装までの暫定) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Padding="8,4,8,4"
                        Background="#F0F0F0">
                <Button x:Name="BackButton" Click="OnBack" IsEnabled="False" ToolTipService.ToolTip="戻る">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                </Button>
                <Button x:Name="ForwardButton" Click="OnForward" IsEnabled="False" ToolTipService.ToolTip="進む">
                    <FontIcon Glyph="&#xE72A;" FontSize="14"/>
                </Button>
                <Button x:Name="UpButton" Click="OnUp" IsEnabled="False" ToolTipService.ToolTip="上へ">
                    <FontIcon Glyph="&#xE74A;" FontSize="14"/>
                </Button>
                <Button x:Name="SplitVButton" Click="OnSplitVertical" FontSize="12"
                        Content="縦分割" ToolTipService.ToolTip="このペインを左右に分割"/>
                <Button x:Name="SplitHButton" Click="OnSplitHorizontal" FontSize="12"
                        Content="横分割" ToolTipService.ToolTip="このペインを上下に分割"/>
                <TextBlock x:Name="PathText" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- アクティブタブのファイル一覧(タブごとに使い回す共有ビュー) -->
            <views:FileListView x:Name="FileList" Grid.Row="2"/>
        </Grid>
    </Border>
</UserControl>
